      "versionNonce": 350990761,
      "text": "•  /{tenantSlug}/admin/staff  (UI calls account-be)\n       send / list / withdraw / RESEND  invitations\n•  /welcome   ← KEPT as in-app post-login surface:\n       - OrgInvitationTable (lists pending invites by claims.email)\n       - in-app Accept / Decline buttons\n       - Kundencenter ?code= → /org-setup\n       - JoinOrgAlert / OrgManualSetup\n•  Trusts: every entrant has a valid Ory session AND\n    is already a member of {tenantSlug}\n    (TenantIdAuthorizationMiddleware enforces)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "•  /{tenantSlug}/admin/staff  (UI calls account-be)\n       send / list / withdraw / RESEND  invitations\n•  /welcome   ← KEPT as in-app post-login surface:\n       - OrgInvitationTable (lists pending invites by claims.email)\n       - in-app Accept / Decline buttons\n       - Kundencenter ?code= → /org-setup\n       - JoinOrgAlert / OrgManualSetup\n•  Trusts: every entrant has a valid Ory session AND\n    is already a member of {tenantSlug}\n    (TenantIdAuthorizationMiddleware enforces)",
      "lineHeight": 1.25,
      "index": "b4S",
      "autoResize": true
    },
