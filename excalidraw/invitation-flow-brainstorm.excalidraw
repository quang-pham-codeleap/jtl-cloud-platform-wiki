      "versionNonce": 1908169993,
      "text": "Security model  —  required checks on the accept path",
      "fontSize": 22,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 19,
      "containerId": null,
      "originalText": "Security model  —  required checks on the accept path",
