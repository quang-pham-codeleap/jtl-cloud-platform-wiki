      "seed": 868774288,
      "versionNonce": 1365003120,
      "text": "ROUTE:\n  /_authenticated/welcome   (search: ?token=…)\n\nWelcome.tsx:\n  •  Existing OrgInvitationTable kept\n  •  NEW: when search.token present, call\n       POST account/invitations/accept { token }\n  •  No-session case continues through Ory via\n       beforeLoadAuthenticated  (return_to preserves ?token=)\n  •  After accept → invalidate ['tenants'] → /{tenantSlug}\n\n",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "ROUTE:\n  /_authenticated/welcome   (search: ?token=…)\n\nWelcome.tsx:\n  •  Existing OrgInvitationTable kept\n  •  NEW: when search.token present, call\n       POST account/invitations/accept { token }\n  •  No-session case continues through Ory via\n       beforeLoadAuthenticated  (return_to preserves ?token=)\n  •  After accept → invalidate ['tenants'] → /{tenantSlug}\n\n",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bI1",
      "autoResize": true
    },
