      "backgroundColor": "transparent",
      "seed": 85979536,
      "versionNonce": 937990544,
      "text": "POST /invitations/exchange:\n  1. re-hash & lookup invitation\n  2. verify expiry, status=New, single-use\n  3. branch by invitee state:\n       State 1: session present → check email match\n                 (mismatch → 409 + clear cookie)\n       State 2: identity exists but no session →\n                 admin-API issue session\n       State 3: no identity → admin-API create\n                 identity ; mark email verified\n                 (link proves email control) ;\n                 admin-API issue session\n  4. Status=Accepted ; null TokenHash ;\n       create TenantMember\n  5. Permit.io sync ; audit log\n\n★ Steps 3.2 & 3.3 bypass normal login + MFA —\nthe link is the authenticator.",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "POST /invitations/exchange:\n  1. re-hash & lookup invitation\n  2. verify expiry, status=New, single-use\n  3. branch by invitee state:\n       State 1: session present → check email match\n                 (mismatch → 409 + clear cookie)\n       State 2: identity exists but no session →\n                 admin-API issue session\n       State 3: no identity → admin-API create\n                 identity ; mark email verified\n                 (link proves email control) ;\n                 admin-API issue session\n  4. Status=Accepted ; null TokenHash ;\n       create TenantMember\n  5. Permit.io sync ; audit log\n\n★ Steps 3.2 & 3.3 bypass normal login + MFA —\nthe link is the authenticator.",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bWg",
      "autoResize": true
