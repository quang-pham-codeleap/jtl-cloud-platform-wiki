      "seed": 1427192208,
      "versionNonce": 1332601232,
      "text": "Loader (runs before any UI):\n  POST  account/invitations/exchange { token }\n\nServer returns:\n  •  Set-Cookie: ory_session=… (HttpOnly, .jtl-cloud.com)\n  •  { tenantSlug }\n\nFE then performs:\n  window.location = {HubBaseUrl}/{tenantSlug}\n\nNo password form is ever shown.\nNo MFA challenge unless the tenant's policy\nexplicitly demands it.\n\n",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "Loader (runs before any UI):\n  POST  account/invitations/exchange { token }\n\nServer returns:\n  •  Set-Cookie: ory_session=… (HttpOnly, .jtl-cloud.com)\n  •  { tenantSlug }\n\nFE then performs:\n  window.location = {HubBaseUrl}/{tenantSlug}\n\nNo password form is ever shown.\nNo MFA challenge unless the tenant's policy\nexplicitly demands it.\n\n",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bWc",
      "autoResize": true
