      "seed": 310061456,
      "versionNonce": 534975344,
      "text": "Domain — TenantInvitation += {\n    TokenHash, ExpiresAt, AcceptedAt,\n    RevokedAt, ResendCount, LastResentAt }\n\nServices:\n  •  InvitationTokenGenerator (256-bit, sha256-hash)\n  •  LinkService.GetInvitationLink(token) →\n       '{HubBaseUrl}/welcome?token={token}'\n\nNEW endpoints:\n  GET   invitations/verify?token=…   (ANONYMOUS)\n  POST  invitations/accept { token } (bearer + match)\n  POST  tenants/{tid}/invitations/{id}/resend\n\nMODIFIED endpoints:\n  POST  tenants/{tid}/invitations/{id}/accept\n       (email-match guard added — §8.1)\n\nAccept handler ALWAYS verifies:\n  hash · expiry · status=New · email-match · Ory verified",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "Domain — TenantInvitation += {\n    TokenHash, ExpiresAt, AcceptedAt,\n    RevokedAt, ResendCount, LastResentAt }\n\nServices:\n  •  InvitationTokenGenerator (256-bit, sha256-hash)\n  •  LinkService.GetInvitationLink(token) →\n       '{HubBaseUrl}/welcome?token={token}'\n\nNEW endpoints:\n  GET   invitations/verify?token=…   (ANONYMOUS)\n  POST  invitations/accept { token } (bearer + match)\n  POST  tenants/{tid}/invitations/{id}/resend\n\nMODIFIED endpoints:\n  POST  tenants/{tid}/invitations/{id}/accept\n       (email-match guard added — §8.1)\n\nAccept handler ALWAYS verifies:\n  hash · expiry · status=New · email-match · Ory verified",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bI5",
      "autoResize": true
    },
