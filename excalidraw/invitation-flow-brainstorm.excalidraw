      "version": 86,
      "fillStyle": "solid",
      "id": "w-lpdAvH6N56rZYBVN2rY",
      "type": "text",
      "x": 1106.0555965318981,
      "y": -554.9263144640327,
      "width": 368,
      "height": 229,
      "strokeColor": "#5c5f66",
      "backgroundColor": "transparent",
      "seed": 1604402032,
      "versionNonce": 553282928,
      "text": "No /invite route added.\nNo modules/invitation/ created.\n\nDisplay-only pending-invite list under\n/account/general/organizations stays as today.\n\nAccount-fe's existing _anonymous/auth/registration\nand _anonymous/auth/verification routes are still\nused transparently — Ory's bounce hits them — but\nthey're not customized for invitations.\n\nWrong-account UX is the weakest spot in this\nscenario: a logged-in user with the wrong session\njust sees an empty /welcome and is left to figure\nout 'log out, log back in as X' by themselves.",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "No /invite route added.\nNo modules/invitation/ created.\n\nDisplay-only pending-invite list under\n/account/general/organizations stays as today.\n\nAccount-fe's existing _anonymous/auth/registration\nand _anonymous/auth/verification routes are still\nused transparently — Ory's bounce hits them — but\nthey're not customized for invitations.\n\nWrong-account UX is the weakest spot in this\nscenario: a logged-in user with the wrong session\njust sees an empty /welcome and is left to figure\nout 'log out, log back in as X' by themselves.",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bEW",
      "autoResize": true
    },
