      "fillStyle": "solid",
      "id": "I16EBSuHyLrk2BMABNcd_",
      "type": "text",
      "x": 9204.43661267644,
      "y": -274.81604589561675,
      "width": 706.4,
      "height": 154,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "seed": 726143856,
      "versionNonce": 1223177072,
      "text": "How each invitee state is handled:\n\n  State 1  (already logged in):\n    Ory detects session; if email matches → after_login hook → membership; if not → 're-auth' UI.\n\n  State 2  (has account, logged out):\n    Ory shows login form (login_hint prefilled); after_login hook fires; membership created.\n\n  State 3  (no Ory account yet):\n    Ory shows registration form (email_hint prefilled); PostIdentityCreation fires; membership.",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "How each invitee state is handled:\n\n  State 1  (already logged in):\n    Ory detects session; if email matches → after_login hook → membership; if not → 're-auth' UI.\n\n  State 2  (has account, logged out):\n    Ory shows login form (login_hint prefilled); after_login hook fires; membership created.\n\n  State 3  (no Ory account yet):\n    Ory shows registration form (email_hint prefilled); PostIdentityCreation fires; membership.",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bT6",
      "autoResize": true
    },
