      "backgroundColor": "transparent",
      "seed": 48480144,
      "versionNonce": 1486970224,
      "text": "How each invitee state is handled:\n\n  State 1  (already logged in):\n    /welcome calls verify endpoint, compares claims.email vs preview; on match → accept; on mismatch → 'wrong account'.\n\n  State 2  (has account, logged out):\n    Standard Ory login bounce with return_to=/welcome?token=…; resumes the State-1 flow with a session.\n\n  State 3  (no Ory account yet):\n    Same bounce, but Ory shows the registration form; verification mail; back to /welcome?token=…",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "How each invitee state is handled:\n\n  State 1  (already logged in):\n    /welcome calls verify endpoint, compares claims.email vs preview; on match → accept; on mismatch → 'wrong account'.\n\n  State 2  (has account, logged out):\n    Standard Ory login bounce with return_to=/welcome?token=…; resumes the State-1 flow with a session.\n\n  State 3  (no Ory account yet):\n    Same bounce, but Ory shows the registration form; verification mail; back to /welcome?token=…",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bI2",
      "autoResize": true
    },
