      "width": 360.8,
      "height": 274,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "seed": 861847408,
      "versionNonce": 1650909040,
      "text": "hub-fe:\n  •  /welcome can keep its in-app list (optional)\n  •  /admin/staff unchanged\n\naccount-fe:\n  •  NO custom /invite page; users land on Ory UI\n  •  Tiny 'redirecting…' splash on\n      /invitations/finalize while the webhook\n      writes the membership\n\nTrade-off cost across all 3 states:\n  •  pre-accept preview ('you are joining\n      {tenantName} as {role}') is awkward —\n      Ory drives the page, not us\n  •  branding/copy on the registration form is\n      whatever Ory's UI allows\n  •  State-1 mismatch surfaces as Ory's own\n      'logged in as different user' UI",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "hub-fe:\n  •  /welcome can keep its in-app list (optional)\n  •  /admin/staff unchanged\n\naccount-fe:\n  •  NO custom /invite page; users land on Ory UI\n  •  Tiny 'redirecting…' splash on\n      /invitations/finalize while the webhook\n      writes the membership\n\nTrade-off cost across all 3 states:\n  •  pre-accept preview ('you are joining\n      {tenantName} as {role}') is awkward —\n      Ory drives the page, not us\n  •  branding/copy on the registration form is\n      whatever Ory's UI allows\n  •  State-1 mismatch surfaces as Ory's own\n      'logged in as different user' UI",
      "lineHeight": 1.25,
      "strokeWidth": 2,
      "index": "bTC",
      "autoResize": true
    },
